# ─── Smart Contract ──────────────────────────────────────────────────────────
# Paste your deployed contract address here after running: npm run deploy:sepolia
NEXT_PUBLIC_CONTRACT_ADDRESS=0xYourContractAddressHere

# ─── Network ─────────────────────────────────────────────────────────────────
# Sepolia = 11155111 | Zama devnet = 8009
NEXT_PUBLIC_CHAIN_ID=11155111
NEXT_PUBLIC_NETWORK_NAME=Sepolia

# ─── FHEVM Gateway (Sepolia Coprocessor) ─────────────────────────────────────
NEXT_PUBLIC_FHEVM_GATEWAY=https://gateway.sepolia.zama.ai
